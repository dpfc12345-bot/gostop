{
  "name": "@gostop/web",
  "version": "0.0.0",
  "private": true,
  "description": "Player web client (React + Vite + TailwindCSS). Web and mobile browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "assets:cards": "tsx scripts/build-card-assets.ts"
  },
  "dependencies": {
    "@gostop/engine": "workspace:*",
    "@gostop/shared": "workspace:*",
    "framer-motion": "^12.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  }
}
